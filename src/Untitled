import React, { useState, useEffect } from 'react';
import { 
  Plus, Search, School, Edit3, Trash2, 
  AlertCircle, Loader2, Building2, GraduationCap, 
  MapPin, Settings, Power, PowerOff, ExternalLink,
  ShieldCheck, ArrowRight
} from 'lucide-react';
import api from '../../api/axiosConfig';
import ModalOrganizacion from './ModalOrganizacion';
import { useNavigate } from 'react-router-dom';

export default function OrganizacionesPage() {
  const [organizaciones, setOrganizaciones] = useState([]);
  const [busqueda, setBusqueda] = useState("");
  const [filtroTipo, setFiltroTipo] = useState("Todos");
  const [isModalOpen, setIsModalOpen] = useState(false);
  const [orgAEditar, setOrgAEditar] = useState(null);
  const [loading, setLoading] = useState(true);
  const navigate = useNavigate();

  const tiposDisponibles = ["Todos", "Facultad", "Administración", "Escuela", "Sede"];

  useEffect(() => { fetchOrganizaciones(); }, []);
  
  const fetchOrganizaciones = async () => {
    setLoading(true);
    try {
      const response = await api.get('/Organizacion');
      setOrganizaciones(response.data);
    } catch (error) {
      console.error("Error de sincronización:", error);
    } finally {
      setLoading(false);
    }
  };

  // 🖱️ NAVEGACIÓN A DETALLES (Portal Estudiante)
  const irADetalles = (id) => {
    navigate(`/organizaciones/${id}`);
  };

  // 🔄 CONMUTAR ESTADO (Toggle Lógico)
  const handleToggleStatus = async (e, org) => {
    e.stopPropagation(); // Evita navegar al detalle al pulsar el botón
    const accion = org.estaActivo ? "DESACTIVAR" : "ACTIVAR";
    if (!window.confirm(`¿Seguro que deseas ${accion} la unidad: ${org.nombre}?`)) return;

    try {
      await api.patch(`/Organizacion/${org.id}/toggle-status`);
      fetchOrganizaciones();
    } catch (error) {
      alert("❌ Error al cambiar el estado");
    }
  };

  // 🗑️ ELIMINACIÓN PERMANENTE (Borrado Físico)
  const handleDelete = async (e, org) => {
    e.stopPropagation(); // Evita navegar al detalle
    const confirmar = window.confirm(
      `🚨 ELIMINACIÓN PERMANENTE: ${org.nombre}\n\n` +
      `¿Deseas borrarla definitivamente de la base de datos?\n` +
      `Esta acción fallará si existen usuarios o registros vinculados.`
    );

    if (!confirmar) return;

    try {
      const response = await api.delete(`/Organizacion/${org.id}`);
      alert(`✅ ${response.data.message}`);
      fetchOrganizaciones();
    } catch (error) {
      const errorData = error.response?.data;
      alert(`🚫 OPERACIÓN DENEGADA:\n${errorData?.detail || errorData?.message || "Error de integridad"}`);
    }
  };

  const abrirEdicion = (e, org) => {
    e.stopPropagation(); // Evita navegar al detalle
    setOrgAEditar(org);
    setIsModalOpen(true);
  };

  const filtrados = organizaciones.filter(o => {
    const matchBusqueda = (o.nombre?.toLowerCase().includes(busqueda.toLowerCase()) ||
                          o.abreviatura?.toLowerCase().includes(busqueda.toLowerCase()));
    const matchTipo = filtroTipo === "Todos" || o.tipo === filtroTipo;
    return matchBusqueda && matchTipo;
  });

  const getIcon = (tipo) => {
    switch(tipo) {
      case 'Facultad': return <GraduationCap size={14} />;
      case 'Administración': return <Settings size={14} />;
      case 'Sede': return <MapPin size={14} />;
      default: return <Building2 size={14} />;
    }
  };

  return (
    <div className="space-y-8 animate-fade-in font-montserrat pb-20 text-slate-800 px-2">
      
      {/* HEADER: VISTA SUPER ADMIN */}
      <div className="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 bg-white/60 backdrop-blur-md p-8 rounded-[2.5rem] border border-white shadow-xl shadow-slate-200/40">
        <div className="flex items-center gap-5">
          <div className="p-4 bg-slate-900 text-white rounded-[1.5rem] shadow-2xl rotate-3 hover:rotate-0 transition-transform duration-500">
            <ShieldCheck size={28} />
          </div>
          <div>
            <h2 className="text-2xl font-black uppercase tracking-tighter flex items-center gap-3">
              Estructura Maestro <span className="text-[10px] bg-primary/10 text-primary px-3 py-1 rounded-full tracking-widest font-black uppercase">Root Access</span>
            </h2>
            <p className="text-[10px] font-bold text-slate-400 uppercase tracking-[0.3em] italic">Configuración global de unidades institucionales</p>
          </div>
        </div>

        <button 
          onClick={() => { setOrgAEditar(null); setIsModalOpen(true); }} 
          className="w-full md:w-auto bg-primary text-white px-10 py-5 rounded-[2rem] font-black text-xs uppercase tracking-[0.2em] hover:bg-green-700 hover:-translate-y-1 transition-all shadow-2xl shadow-primary/20 flex items-center justify-center gap-3 active:scale-95"
        >
          <Plus size={18} strokeWidth={3} /> Registrar Unidad
        </button>
      </div>

      {/* FILTROS INTEGRADOS */}
      <div className="flex flex-col lg:flex-row gap-4 items-center">
        <div className="relative group w-full lg:max-w-md">
          <Search className="absolute left-5 top-1/2 -translate-y-1/2 text-slate-300 group-focus-within:text-primary transition-colors" size={20} />
          <input 
            type="text" 
            placeholder="Buscar por nombre, siglas..." 
            className="w-full pl-14 pr-6 py-5 rounded-[2rem] border-none bg-white shadow-lg shadow-slate-200/30 focus:ring-4 focus:ring-primary/5 focus:border-primary outline-none transition-all font-semibold text-sm"
            value={busqueda}
            onChange={(e) => setBusqueda(e.target.value)}
          />
        </div>

        <div className="flex bg-slate-100/50 p-1.5 rounded-[1.5rem] border border-slate-200/50 w-full overflow-x-auto no-scrollbar backdrop-blur-sm">
          {tiposDisponibles.map((tipo) => (
            <button
              key={tipo}
              onClick={() => setFiltroTipo(tipo)}
              className={`flex-1 px-6 py-3.5 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all whitespace-nowrap ${filtroTipo === tipo ? 'bg-white text-slate-900 shadow-sm border border-slate-200 scale-[1.02]' : 'text-slate-400 hover:text-slate-600'}`}
            >
              {tipo}
            </button>
          ))}
        </div>
      </div>

      {/* GRID DE UNIDADES */}
      <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
        {loading ? (
          <div className="col-span-full py-32 flex flex-col items-center gap-6">
            <Loader2 className="animate-spin text-primary" size={40} />
            <p className="font-black text-slate-300 text-xs uppercase tracking-[0.4em] animate-pulse">Sincronizando Registros Maestro</p>
          </div>
        ) : filtrados.length > 0 ? (
          filtrados.map((org) => (
            <div 
              key={org.id} 
              onClick={() => irADetalles(org.id)}
              className={`group relative bg-white rounded-[2.5rem] border cursor-pointer transition-all duration-500 flex flex-col overflow-hidden hover:shadow-[0_30px_60px_-15px_rgba(0,0,0,0.1)] hover:-translate-y-3 ${!org.estaActivo ? 'border-slate-100' : 'border-slate-200 shadow-sm'}`}
            >
              {/* Identidad de Color Dinámica */}
              <div className="h-2 w-full" style={{ backgroundColor: org.estaActivo ? (org.colorRepresentativo || '#cbd5e1') : '#e2e8f0' }}></div>
              
              <div className="p-8 flex flex-col flex-1 space-y-6">
                <div className="flex justify-between items-start">
                  <div className={`w-16 h-16 rounded-[1.5rem] bg-slate-50 border border-slate-100 flex items-center justify-center p-3 shadow-inner transition-transform duration-500 group-hover:scale-110 group-hover:rotate-3 ${!org.estaActivo && 'grayscale opacity-50'}`}>
                    {org.logoUrl ? <img src={org.logoUrl} className="w-full h-full object-contain" alt="Logo" /> : <School className="text-slate-300" size={32} />}
                  </div>
                  
                  {/* ACCIONES SUPER ADMIN (Flotantes) */}
                  <div className="flex gap-1.5 bg-slate-50/80 backdrop-blur-md p-1.5 rounded-xl border border-slate-100 opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 transition-all duration-300">
                    <button onClick={(e) => abrirEdicion(e, org)} className="p-2 text-slate-400 hover:text-orange-500 hover:bg-white rounded-lg transition-all shadow-sm active:scale-90" title="Editar"><Edit3 size={15} /></button>
                    <button onClick={(e) => handleToggleStatus(e, org)} className={`p-2 rounded-lg transition-all shadow-sm active:scale-90 ${org.estaActivo ? 'text-slate-400 hover:text-blue-500 hover:bg-white' : 'text-blue-500 bg-white'}`} title={org.estaActivo ? "Desactivar" : "Activar"}>
                      {org.estaActivo ? <Power size={15} /> : <PowerOff size={15} />}
                    </button>
                    <button onClick={(e) => handleDelete(e, org)} className="p-2 text-slate-400 hover:text-red-500 hover:bg-white rounded-lg transition-all shadow-sm active:scale-90" title="Eliminar"><Trash2 size={15} /></button>
                  </div>
                </div>

                <div className="space-y-2">
                  <div className="flex items-center gap-2">
                    <span className={`text-[8px] font-black px-2 py-0.5 rounded-md border ${org.estaActivo ? 'bg-slate-900 text-white border-slate-900' : 'bg-slate-100 text-slate-400 border-slate-200'}`}>
                      {org.abreviatura}
                    </span>
                    <span className="text-[8px] font-black text-slate-400 uppercase tracking-widest flex items-center gap-1">
                      {getIcon(org.tipo)} {org.tipo}
                    </span>
                  </div>
                  <h3 className={`text-lg font-black uppercase italic leading-tight tracking-tighter transition-colors ${org.estaActivo ? 'text-slate-800 group-hover:text-primary' : 'text-slate-300'}`}>
                    {org.nombre}
                  </h3>
                </div>

                <div className="pt-6 mt-auto border-t border-slate-50 flex items-center justify-between">
                   <div className="flex items-center gap-2.5">
                      <div className="w-3 h-3 rounded-full border-2 border-white shadow-md" style={{ backgroundColor: org.estaActivo ? org.colorRepresentativo : '#cbd5e1' }}></div>
                      <span className="text-[8px] font-bold text-slate-300 uppercase tracking-widest italic">ID: {org.id}</span>
                   </div>
                   <div className={`flex items-center gap-2 px-3 py-1 rounded-full text-[8px] font-black uppercase tracking-tighter ${org.estaActivo ? 'bg-emerald-50 text-emerald-600' : 'bg-slate-50 text-slate-300'}`}>
                      <div className={`w-1.5 h-1.5 rounded-full ${org.estaActivo ? 'bg-emerald-500 animate-pulse shadow-[0_0_8px_rgba(16,185,129,0.5)]' : 'bg-slate-300'}`}></div>
                      {org.estaActivo ? 'Online' : 'Offline'}
                   </div>
                </div>
                
                {/* Indicador visual de portal (Premium) */}
                <div className="absolute top-1/2 right-4 -translate-y-1/2 opacity-0 group-hover:opacity-20 group-hover:translate-x-0 translate-x-4 transition-all duration-500 pointer-events-none">
                  <ArrowRight size={80} strokeWidth={1} className="text-slate-900" />
                </div>
              </div>
            </div>
          ))
        ) : (
          <div className="col-span-full py-24 text-center border-4 border-dashed border-slate-100 rounded-[3rem] flex flex-col items-center gap-4 bg-slate-50/50">
            <AlertCircle size={48} className="text-slate-200" />
            <p className="text-slate-400 font-black uppercase text-xs tracking-[0.3em] italic">Sin registros en esta categoría</p>
            <button onClick={() => {setBusqueda(""); setFiltroTipo("Todos");}} className="bg-white px-6 py-2 rounded-full text-[10px] font-black uppercase shadow-sm hover:shadow-md transition-all border border-slate-100 mt-2">Reiniciar</button>
          </div>
        )}
      </div>

      {isModalOpen && (
        <ModalOrganizacion 
          isOpen={isModalOpen}
          onClose={() => { setIsModalOpen(false); setOrgAEditar(null); }}
          onRefresh={fetchOrganizaciones}
          editarOrg={orgAEditar}
        />
      )}
    </div>
  );
}